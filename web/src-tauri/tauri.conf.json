{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aiko",
  "version": "0.1.0",
  "identifier": "dev.bluna.aiko",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aiko",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "visible": true
      },
      {
        "label": "persona",
        "url": "index.html#/persona",
        "title": "Aiko",
        "width": 320,
        "height": 480,
        "minWidth": 220,
        "minHeight": 280,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": true,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": {
      "../../config/default.json": "config/default.json",
      "../../data/persona/aiko_companion.txt": "data/persona/aiko_companion.txt",
      "../../live-2d-models/Alexia": "data/personas/active/Alexia",
      "../../scripts/setup-macos.sh": "scripts/setup-macos.sh",
      "../../scripts/macos-start-backend.sh": "scripts/macos-start-backend.sh",
      "../../pyproject.toml": "pyproject.toml",
      "../../app": "app"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
