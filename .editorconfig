# EditorConfig — http://EditorConfig.org
#
# Unified formatting rules across the assistant repo. Settings here are
# honoured by VS Code (with the EditorConfig extension), the JetBrains
# IDEs, and any other editor that ships an EditorConfig plugin. They
# pair with the project's other formatters (ruff for Python, prettier
# for the web bundle, rustfmt for the Tauri shell) — this file pins the
# things those formatters don't, primarily file encoding and EOL.
#
# The most important guarantee: every text file is UTF-8 with LF line
# endings so console output from cross-platform tools (PowerShell on
# Windows, bash on macOS / Linux) renders the same characters everywhere.

root = true

# ── Defaults applied to every file ────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# ── Python (matches ruff line-length=100 in pyproject.toml) ───────────
[*.{py,pyi}]
indent_size = 4
max_line_length = 100

# ── Web bundle (React + Vite + TS) ────────────────────────────────────
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

[*.{css,scss,html}]
indent_size = 2

# ── Tauri shell (Rust) ────────────────────────────────────────────────
[*.rs]
indent_size = 4

# ── Config / data files ──────────────────────────────────────────────-
[*.{json,jsonc,yml,yaml,toml}]
indent_size = 2

# ── Docs ─────────────────────────────────────────────────────────────-
# Keep trailing whitespace in markdown: two trailing spaces are a hard
# line break in CommonMark and we use them in tables / docs.
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# ── Shell / scripts ───────────────────────────────────────────────────
[*.sh]
indent_size = 2

# PowerShell scripts (CRLF is the platform default; keep LF for git
# consistency, the .ps1 still runs fine in PowerShell 7+).
[*.ps1]
indent_size = 4

# ── Live2D rig assets — leave binary / vendored files alone ───────────
[*.{moc3,model3.json,physics3.json,exp3.json,motion3.json}]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

# Makefile-style files require literal tabs.
[Makefile]
indent_style = tab

# ── Generated / vendored — opt out completely ─────────────────────────
[{package-lock.json,pnpm-lock.yaml,yarn.lock,Cargo.lock}]
indent_style = unset
indent_size = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
