{
  "agent": {
    "num_history_runs": 10,
    "compress_tool_results": true,
    "compress_tool_results_limit": 3,
    "compress_token_limit": null
  },
  "assistant": {
    "name": "Assistant",
    "remember_history": true,
    "background": "",
    "background_path": "data/assistant_background.txt",
    "response_style": "balanced",
    "tts_length_scale": 1.0
  },
  "ollama": {
    "base_url": "http://127.0.0.1:11434",
    "chat_model": "jaahas/qwen3.5-uncensored:9b",
    "temperature": 0.6,
    "context_window": null,
    "embedding_model": "qwen3-embedding:0.6b"
  },
  "audio": {
    "sample_rate": 16000,
    "channels": 1,
    "enable_microphone": true,
    "microphone_device": null,
    "vad_level_threshold": 0.02,
    "vad_silence_seconds": 1.0,
    "barge_in_enabled": false
  },
  "database": {
    "provider": "sqlite",
    "url": null
  },
  "stt": {
    "model": "large-v1",
    "language": "en"
  },
  "tts": {
    "provider": "kokoro",
    "voice": "af_heart",
    "enabled": true,
    "kokoro_model_path": "models/kokoro-v1.0.onnx",
    "kokoro_voices_path": "models/voices-v1.0.bin",
    "pykokoro_pause_mode": "auto",
    "sbv2_model_path": "",
    "sbv2_device": "cpu",
    "sbv2_language": "EN",
    "sbv2_style": "Neutral",
    "sbv2_style_weight": 1.0
  },
  "ui": {
    "window_x": null,
    "window_y": null,
    "window_width": null,
    "window_height": null
  },
  "tooling": {
    "config_default_path": "config/tooling.default.json",
    "config_user_path": "config/tooling.user.json"
  },
  "logging": {
    "level": "INFO"
  }
