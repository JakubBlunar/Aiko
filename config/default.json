{
  "assistant": {
    "name": "Aiko",
    "remember_history": true,
    "tts_length_scale": 1.0
  },
  "ollama": {
    "base_url": "http://127.0.0.1:11434",
    "chat_model": "jaahas/qwen3.5-uncensored:9b",
    "temperature": 0.6,
    "context_window": null
  },
  "chat_llm": {
    "provider": "ollama",
    "max_tokens": 512,
    "keep_alive": "30m"
  },
  "agent": {
    "proactive_silence_seconds": 45,
    "proactive_cooldown_seconds": 120,
    "summary_idle_seconds": 15,
    "summary_min_unsummarized_messages": 6,
    "summary_target_tokens": 600,
    "max_prompt_tokens_pct": 0.8,
    "scheduler_idle_seconds": 20,
    "scheduler_speaking_window_grace_ms": 200,
    "scheduler_max_job_seconds": 8,
    "reflection_min_seconds_between": 8,
    "reflection_emotional_delta_threshold": 0.05,
    "user_profile_min_turns": 6,
    "agenda_groom_every_n_turns": 8,
    "arc_update_every_n_turns": 1,
    "self_image_pulse_enabled": true,
    "prepared_nudge_ttl_seconds": 600,
    "filler_enabled": true,
    "filler_first_token_ms": 800,
    "consolidator_enabled": true,
    "consolidator_min_hours_between": 18,
    "consolidator_chunk_size": 40,
    "consolidator_similarity_threshold": 0.84,
    "consolidator_min_cluster_size": 2,
    "consolidator_use_llm_merge": true,
    "relationship_pulse_enabled": true,
    "relationship_pulse_min_hours": 168,
    "relationship_pulse_min_turns": 30,
    "cadence_enabled": true
  },
  "audio": {
    "sample_rate": 16000,
    "channels": 1,
    "enable_microphone": true,
    "microphone_device": null,
    "vad_level_threshold": 0.02,
    "vad_silence_seconds": 1.0,
    "barge_in_enabled": false
  },
  "stt": {
    "model": "large-v1",
    "language": "en"
  },
  "tts": {
    "provider": "pocket-tts",
    "voice": "aiko1_refined.safetensors",
    "enabled": true,
    "pocket_tts_voice": "aiko1_refined.safetensors",
    "pocket_tts_temp": 0.6
  },
  "logging": {
    "level": "INFO",
    "module_levels": {},
    "file_enabled": true,
    "file_path": "data/app.log",
    "file_max_bytes": 5242880,
    "file_backup_count": 5
  },
  "mcp_server": {
    "enabled": true,
    "port": 6274
  },
  "web_server": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 6275
  },
  "memory": {
    "enabled": true,
    "top_k": 6,
    "score_threshold": 0.4,
    "max_memories": 500,
    "dedupe_threshold": 0.92,
    "extractor_enabled": true,
    "self_tagged_salience": 0.7
  },
  "tools": {
    "enabled": true,
    "get_time": true,
    "recall": true,
    "web_search": true
  },
  "endpointing": {
    "enabled": true,
    "use_partial_transcript": true,
    "phrase_silence_seconds": 1.0,
    "turn_silence_seconds": 3.0,
    "fast_close_silence_seconds": 0.6,
    "hesitation_extend_to_turn": true,
    "barge_in_min_speech_seconds": 0.7
  },
  "avatar": {
    "root_dir": "live-2d-models/Alexia",
    "entry_filename": "Alexia.model3.json",
    "scale_multiplier": 1.0,
    "auto_outfit": "auto",
    "expressiveness": 1.0
  }
}
