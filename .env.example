# Copy to `.env` and tweak. All values are optional — the defaults below
# match docker-compose.yml.

# Image profile: slim (text + avatar) or full (adds server-side voice).
AIKO_PROFILE=slim

# Host port the web UI is published on (container always listens on 6275).
AIKO_PORT=6275

# Where Aiko finds Ollama.
#  - Host Ollama (default):           http://host.docker.internal:11434
#  - In-compose Ollama (--profile with-ollama): http://ollama:11434
AIKO_OLLAMA_BASE_URL=http://host.docker.internal:11434

# Host port for the optional in-compose Ollama service.
OLLAMA_PORT=11434
