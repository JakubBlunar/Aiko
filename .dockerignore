# Keep the build context small and never ship dev/user state into the image.

# VCS / tooling
.git
.gitignore
.github
.cursor
.cursorrules
AGENTS.md
agent-transcripts
*.md
!README.md

# Python caches / envs
.venv
venv
__pycache__
**/__pycache__
*.pyc
*.pyo
.pytest_cache
.ruff_cache
.mypy_cache

# Node — frontend deps + build output are reinstalled/rebuilt in the image
node_modules
web/node_modules
web/dist
web/.vite

# Tauri desktop build artifacts (irrelevant to the container)
web/src-tauri/target
web/src-tauri/gen

# Tests
tests

# Runtime / user state under data/. The persona text + the active avatar
# bundle are kept (baked outside the volume and seeded into it on first
# boot); everything else under data/ is dev/user state and must not ship.
data/*.db
data/*.db-shm
data/*.db-wal
data/lancedb
data/documents
data/attachments
# Exclude persona runtime state, but keep the active avatar bundle so the
# image can seed it into the data volume on first boot.
data/personas/*
!data/personas/active
data/personas/active/runtime
data/uploads
data/app.log*
data/crashlog.txt
data/persona/self_image.txt
data/persona/golden_turns.jsonl

# Local config overrides + secrets must never be baked in
config/user.json
.env

# Misc
*.log
.DS_Store
